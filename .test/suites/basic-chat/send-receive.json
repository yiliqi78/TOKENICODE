{
  "tests": [
    {
      "name": "T01-基础发送接收(#57#64回归)",
      "timeout": 90000,
      "retry": 1,
      "setup": [
        {
          "cmd": "new-session",
          "flags": {
            "cwd": "/tmp/tokenicode-test"
          }
        },
        {
          "cmd": "check-editor",
          "assert": {
            "hasEditor": true
          }
        },
        {
          "cmd": "switch-model",
          "args": [
            "claude-sonnet-4-6"
          ]
        }
      ],
      "steps": [
        {
          "cmd": "type",
          "args": [
            "请只回复两个字：收到"
          ]
        },
        {
          "cmd": "send"
        },
        {
          "cmd": "wait-until-done",
          "flags": {
            "timeout": "60000"
          },
          "assert": {
            "status": "completed"
          },
          "timeout": 65000
        },
        {
          "cmd": "get-messages",
          "assert": {
            "total_gte": 2
          }
        },
        {
          "cmd": "status",
          "assert": {
            "active": false
          }
        }
      ],
      "teardown": [
        {
          "cmd": "stop",
          "continueOnError": true
        },
        {
          "cmd": "delete-session",
          "continueOnError": true
        }
      ]
    },
    {
