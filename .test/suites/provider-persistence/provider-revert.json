{
  "tests": [
    {
      "name": "T01-发消息后provider不回退(#47)",
      "timeout": 120000,
      "retry": 1,
      "setup": [
        {
          "cmd": "new-session",
          "flags": {
            "cwd": "/tmp/tokenicode-test"
          }
        },
        {
          "cmd": "check-editor",
          "assert": {
            "hasEditor": true
          }
        },
        {
          "cmd": "switch-model",
          "args": [
            "claude-sonnet-4-6"
          ]
        },
        {
          "cmd": "switch-provider",
          "args": [
            "null"
          ]
        }
      ],
      "steps": [
        {
          "cmd": "get-current-provider"
        },
        {
          "cmd": "type",
          "args": [
            "请只回复：OK"
          ]
        },
        {
          "cmd": "send"
        },
        {
          "cmd": "wait-until-done",
          "flags": {
            "timeout": "60000"
          },
          "assert": {
            "status": "completed"
          },
          "timeout": 65000
        },
        {
          "cmd": "get-current-provider"
        },
        {
          "cmd": "status",
          "assert": {
            "active": false
          }
        }
      ],
      "teardown": [
        {
          "cmd": "stop",
          "continueOnError": true
        },
        {
          "cmd": "delete-session",
          "continueOnError": true
        }
      ]
    },
