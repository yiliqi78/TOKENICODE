    },
    {
      "name": "T05-设置tab切换-mcp(#53)",
      "timeout": 15000,
      "steps": [
        {
          "cmd": "open-settings"
        },
        {
          "cmd": "switch-settings-tab",
          "args": [
            "mcp"
          ]
        },
        {
