{
  "tests": [
    {
      "name": "T01-基础发送接收",
      "timeout": 90000,
      "retry": 1,
      "setup": [
        {
          "cmd": "new-session",
          "flags": {
            "cwd": "/tmp/tokenicode-test"
          }
        },
        {
          "cmd": "check-editor",
          "assert": {
            "hasEditor": true
          }
        },
        {
          "cmd": "switch-model",
          "args": [
            "claude-sonnet-4-6"
          ]
        }
      ],
      "steps": [
        {
          "cmd": "type",
          "args": [
            "回复OK"
          ]
        },
        {
          "cmd": "send"
        },
        {
          "cmd": "wait-until-done",
          "flags": {
            "timeout": "60000"
          },
          "assert": {
            "status": "completed"
          },
          "timeout": 65000
        },
        {
          "cmd": "get-messages",
          "assert": {
            "total_gte": 2
          }
        },
        {
          "cmd": "status",
          "assert": {
            "active": false
          }
        }
      ],
      "teardown": [
        {
          "cmd": "stop",
          "continueOnError": true
        },
        {
          "cmd": "delete-session",
          "continueOnError": true
        },
        {
          "cmd": "delay",
          "args": [
            "3000"
          ]
        }
      ]
    },
